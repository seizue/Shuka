<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:Shuka.Android.Pages"
       x:Class="Shuka.Android.AppShell"
       Shell.NavBarIsVisible="False"
       Shell.TabBarBackgroundColor="{DynamicResource NavBar}"
       Shell.TabBarForegroundColor="{DynamicResource NavBarSelected}"
       Shell.TabBarUnselectedColor="{DynamicResource NavBarUnselected}"
       Shell.TabBarTitleColor="{DynamicResource NavBarSelected}"
       Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Home"
                      Icon="tab_home.png"
                      ContentTemplate="{DataTemplate pages:MainPage}"
                      Route="MainPage" />
        <ShellContent Title="Downloads"
                      Icon="tab_downloads.png"
                      ContentTemplate="{DataTemplate pages:DownloadsPage}"
                      Route="DownloadsPage" />
        <ShellContent Title="Settings"
                      Icon="tab_settings.png"
                      ContentTemplate="{DataTemplate pages:SettingsPage}"
                      Route="SettingsPage" />
    </TabBar>

</Shell>
