<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="com.seizue.shuka">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Storage: legacy API ≤ 28 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
                     android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
                     android:maxSdkVersion="32" />

    <!-- Foreground service to keep downloads alive in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Broad storage access on Android 11+ for custom paths -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Completion notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required to install APK updates from within the app -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:label="Shuka"
        android:allowBackup="true"
        android:icon="@mipmap/appicon"
        android:roundIcon="@mipmap/appicon_round"
        android:supportsRtl="true">

        <!-- Foreground service for downloads -->
        <service
            android:name="shuka.android.platforms.android.DownloadForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- FileProvider for sharing the downloaded APK with the system installer -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.seizue.shuka.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
