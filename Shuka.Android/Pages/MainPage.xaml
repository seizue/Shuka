<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Shuka.Android.Controls"
             x:Class="Shuka.Android.Pages.MainPage"
             BackgroundColor="{DynamicResource BgPage}">

    <Grid RowDefinitions="Auto,*">

        <!-- Loading overlay -->
        <controls:LoadingOverlay x:Name="LoadingOverlay" Grid.RowSpan="2" />

        <!-- ── Top App Bar ──────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="20,52,20,20"
              BackgroundColor="{DynamicResource BgCard}"
              HeightRequest="120">

            <Border Grid.Column="0"
                    BackgroundColor="{DynamicResource AccentContainer}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    WidthRequest="40" HeightRequest="40"
                    VerticalOptions="Center"
                    Margin="0,0,14,0">
                <Image Source="lily.png"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="Shuka"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="Chinese → English EPUB"
                       FontSize="12"
                       TextColor="{DynamicResource TextMuted}" />
            </VerticalStackLayout>
        </Grid>

        <!-- ── Body ─────────────────────────────────────────── -->
        <ScrollView Grid.Row="1" x:Name="BodyScrollView">
            <VerticalStackLayout Padding="16,20,16,40" Spacing="14">

                <!-- ── Input card ──────────────────────────── -->
                <Border BackgroundColor="{DynamicResource BgCard}"
                        Stroke="{DynamicResource Stroke}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="20,16,20,20">
                    <VerticalStackLayout Spacing="18">

                        <!-- Novel URL -->
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="{DynamicResource IconLink}"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="14"
                                       TextColor="{DynamicResource AccentLight}"
                                       VerticalOptions="Center" />
                                <Label Text="Novel URL"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Border Stroke="{DynamicResource Stroke}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{DynamicResource BgInput}"
                                    Padding="14,0">
                                <Entry x:Name="UrlEntry"
                                       Placeholder="https://czbooks.net/n/..."
                                       Keyboard="Url"
                                       ReturnType="Next"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Cover URL -->
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="{DynamicResource IconImage}"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center" />
                                <Label Text="Cover URL"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextSecondary}"
                                       VerticalOptions="Center" />
                                <Label Text="· optional"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Border Stroke="{DynamicResource Stroke}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{DynamicResource BgInput}"
                                    Padding="14,0">
                                <Entry x:Name="CoverEntry"
                                       Placeholder="https://..."
                                       Keyboard="Url"
                                       ReturnType="Next"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Chapters -->
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="{DynamicResource IconNumbers}"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="14"
                                       TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center" />
                                <Label Text="Chapters"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextSecondary}"
                                       VerticalOptions="Center" />
                                <Label Text="· 0 = all"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Border Stroke="{DynamicResource Stroke}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{DynamicResource BgInput}"
                                    Padding="14,0">
                                <Entry x:Name="ChaptersEntry"
                                       Text="0"
                                       Keyboard="Numeric"
                                       HeightRequest="48" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Download button ─────────────────────── -->
                <Border x:Name="DownloadBtn"
                        BackgroundColor="{DynamicResource Accent}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        HeightRequest="58"
                        Padding="0">
                    <Grid ColumnDefinitions="Auto,*" Padding="22,0">
                        <Label Grid.Column="0"
                               Text="{DynamicResource IconDownload}"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="22"
                               TextColor="{DynamicResource TextOnAccent}"
                               VerticalOptions="Center"
                               Margin="0,0,14,0" />
                        <Label Grid.Column="1"
                               x:Name="DownloadBtnLabel"
                               Text="Download &amp; Translate"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{DynamicResource TextOnAccent}"
                               VerticalOptions="Center" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDownloadClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!-- ── Queued confirmation banner ──────────── -->
                <Border x:Name="QueuedBanner"
                        BackgroundColor="{DynamicResource AccentContainer}"
                        Stroke="{DynamicResource AccentLight}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14"
                        IsVisible="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="{DynamicResource IconDownload}"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="20"
                               TextColor="{DynamicResource AccentLight}"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Download queued!"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{DynamicResource AccentLight}" />
                            <Label Text="Check the Downloads tab to track progress."
                                   FontSize="12"
                                   TextColor="{DynamicResource TextSecondary}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ── Tip card ────────────────────────────── -->
                <Border BackgroundColor="{DynamicResource BgCard}"
                        Stroke="{DynamicResource Stroke}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="{DynamicResource IconInfo}"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="18"
                               TextColor="{DynamicResource TextMuted}"
                               VerticalOptions="Start"
                               Margin="0,1,0,0" />
                        <Label Grid.Column="1"
                               Text="You can queue multiple novels at once. Each download runs independently — switch to the Downloads tab to monitor progress or cancel."
                               FontSize="12"
                               TextColor="{DynamicResource TextMuted}"
                               LineBreakMode="WordWrap" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
